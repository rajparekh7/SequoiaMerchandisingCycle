# Copy to .env.local and fill in. The engine + tests run WITHOUT any of these
# (they use the deterministic mock scorer). These are needed only for live runs.

# Anthropic API — qualitative stage scoring (claude-opus-4-8) and extraction (claude-haiku-4-5)
ANTHROPIC_API_KEY=

# Firecrawl — JS-rendered crawl, returns clean markdown
FIRECRAWL_API_KEY=

# Supabase — report persistence + async job/status table
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
