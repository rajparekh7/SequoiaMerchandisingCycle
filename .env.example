# Copy to .env.local and fill in. The engine + tests run WITHOUT any of these
# (they use the deterministic mock scorer). These are needed only for live runs.

# Anthropic API — qualitative stage scoring (claude-opus-4-8) and extraction (claude-haiku-4-5)
ANTHROPIC_API_KEY=

# Firecrawl — JS-rendered crawl, returns clean markdown
FIRECRAWL_API_KEY=

# Vercel KV / Upstash Redis — shared job+report store for the async flow on serverless.
# Required in production (Vercel); omit locally to use the in-memory fallback.
# Vercel injects these automatically when you attach a KV store to the project.
# (The marketplace Upstash integration uses the UPSTASH_* names — either pair works.)
KV_REST_API_URL=
KV_REST_API_TOKEN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Supabase — V2 persistence (report history/trends). Not needed for V1 deploy.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
