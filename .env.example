# Copy to .env.local and fill in. The engine + tests run WITHOUT any of these
# (they use the deterministic mock scorer). These are needed only for live runs.

# Anthropic API — qualitative stage scoring (claude-opus-4-8) and extraction (claude-haiku-4-5)
ANTHROPIC_API_KEY=

# Firecrawl — JS-rendered crawl, returns clean markdown
FIRECRAWL_API_KEY=

# --- Shared job+report store (pick ONE; required in production on serverless) ---
# The store auto-selects by which vars are set: Supabase > KV > in-memory (local dev).

# Option 1 — Supabase (Postgres, persistent: share links never expire). Needs a `jobs`
# table (see SQL in src/jobs/store.ts). Uses the SERVICE ROLE key (server-only — keep secret).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Option 2 — Vercel KV / Upstash Redis (fast, 1h TTL). Vercel injects these when you attach
# a KV store. The marketplace Upstash integration uses the UPSTASH_* names — either pair works.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
